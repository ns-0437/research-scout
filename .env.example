# Copy to .env and fill in.

# Required: Anthropic API key — Research Scout runs on Claude with live web search.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Signing secret from the SitRep Studio (shown once when you save a Remote agent).
# Leave blank for pure local dev — signature checks are skipped when unset.
SITREP_AGENT_SECRET=

# Optional tuning
CLAUDE_MODEL=claude-opus-4-8
MAX_RESEARCH_ITEMS=4
SEARCHES_PER_ITEM=3
ITEM_TIMEOUT_SECONDS=210
ITEM_STAGGER_SECONDS=2.5
