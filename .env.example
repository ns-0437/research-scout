# Copy to .env and fill in.

# Required: Anthropic API key — Research Scout runs on Claude with live web search.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Signing secret from the SitRep Studio (shown once when you save a Remote agent).
# Leave blank for pure local dev — signature checks are skipped when unset.
SITREP_AGENT_SECRET=

# Optional tuning
CLAUDE_MODEL=claude-opus-4-8
MAX_RESEARCH_ITEMS=4
SEARCHES_PER_ITEM=3
ITEM_TIMEOUT_SECONDS=210
ITEM_STAGGER_SECONDS=2.5

# Optional resiliency fallback: if set, a failed Claude call (e.g. the Anthropic
# account is out of credit) retries once on Gemini instead of degrading the
# artifact. Get a free key at https://aistudio.google.com/apikey. Leave unset
# to run purely on Claude.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
